<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Management System</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
<header class="border-bottom bg-white">
    <nav class="navbar navbar-expand-lg navbar-light container py-3">
        <a class="navbar-brand fw-bold" asp-controller="Inventory" asp-action="Index">Inventory EDA</a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link" asp-controller="Inventory" asp-action="Index">Dashboard</a>
            <a class="nav-link" asp-controller="Inventory" asp-action="Products">Products</a>
            <a class="nav-link" asp-controller="Inventory" asp-action="Suppliers">Suppliers</a>
            <a class="nav-link" asp-controller="Inventory" asp-action="Receive">Receive Stock</a>
            <a class="nav-link" asp-controller="Inventory" asp-action="Remove">Remove Stock</a>
            <a class="nav-link" asp-controller="Inventory" asp-action="Orders">Orders</a>
            <a class="nav-link" asp-controller="Inventory" asp-action="Events">Event History</a>
        </div>
    </nav>
</header>

<main class="container py-4">
    @if (TempData["Message"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }
    @RenderBody()
</main>

<footer class="border-top py-3 mt-5">
    <div class="container text-muted small">
        Event-driven inventory management demo
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
