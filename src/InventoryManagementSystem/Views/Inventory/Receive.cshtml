@model IReadOnlyList<Product>
@{
    ViewData["Title"] = "Receive Stock";
}
<div class="row g-4">
    <div class="col-lg-5">
        <div class="card p-4">
            <h1 class="h4 mb-3">Receive stock</h1>
            <form asp-action="Receive" method="post" class="vstack gap-3">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Product</label>
                    <select class="form-select" name="productId" required>
                        @foreach (var p in Model)
                        {
                            <option value="@p.Id">@p.Name (Current: @p.StockLevel)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Quantity</label>
                    <input class="form-control" type="number" min="1" name="quantity" value="1" required />
                </div>
                <div>
                    <label class="form-label">Received by</label>
                    <input class="form-control" type="text" name="receivedBy" value="Store Clerk" required />
                </div>
                <button class="btn btn-primary">Submit receipt</button>
            </form>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card p-4">
            <h2 class="h5">Products available for receiving</h2>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Stock</th>
                            <th>Threshold</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td>@p.StockLevel</td>
                            <td>@p.ReorderThreshold</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
